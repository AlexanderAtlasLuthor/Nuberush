# NubeRush Driver — example PUBLIC runtime config (Dr.1.4).
#
# PLACEHOLDERS ONLY. Copy your TEST project values in locally and pass them via
# --dart-define (or --dart-define-from-file). Never commit real values.
#
# Public / client-safe values only:
#   - Use the Supabase PUBLIC anon key (never the service-role key).
#   - Missing/invalid values make the app show ConfigRequiredScreen (no crash,
#     no localhost fallback, no network call).
#
# Example run:
#   cd mobile
#   flutter run \
#     --dart-define=NUBERUSH_API_BASE_URL=$NUBERUSH_API_BASE_URL \
#     --dart-define=NUBERUSH_SUPABASE_URL=$NUBERUSH_SUPABASE_URL \
#     --dart-define=NUBERUSH_SUPABASE_ANON_KEY=$NUBERUSH_SUPABASE_ANON_KEY
#
# Or with a git-ignored JSON file (do NOT commit the real one):
#   flutter run --dart-define-from-file=dart_defines.local.json
#   {
#     "NUBERUSH_API_BASE_URL": "https://example-api.example.com",
#     "NUBERUSH_SUPABASE_URL": "https://example-project.supabase.co",
#     "NUBERUSH_SUPABASE_ANON_KEY": "example-anon-key"
#   }

NUBERUSH_API_BASE_URL=https://example-api.example.com
NUBERUSH_SUPABASE_URL=https://example-project.supabase.co
NUBERUSH_SUPABASE_ANON_KEY=example-anon-key
