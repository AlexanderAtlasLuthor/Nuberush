# ---------------------------------------------------------------------------
# NubeRush frontend — environment contract (Vite build-time vars)
#
# Copy this file to web/.env and fill in real values. web/.env is
# gitignored and must never hold committed secrets.
#
# ONLY public, browser-safe values belong here. Vite inlines every
# VITE_*-prefixed var into the client bundle, so anything secret
# (service-role keys, database URLs) is forbidden — see the note below.
# ---------------------------------------------------------------------------

# FastAPI backend base URL. All business reads/writes go through this.
# Local development may use the FastAPI localhost origin (below).
# Production SHOULD set VITE_API_BASE_URL explicitly. If it is missing or
# blank in a production build, the app logs a console warning and falls
# back to the localhost origin (so the public site still renders) — it does
# NOT crash. Business API calls will fail until a real origin is set. This
# will be re-tightened to a hard error once FastAPI has a hosted origin.
VITE_API_BASE_URL=http://localhost:8000

# Supabase Auth — used for sign-in / session persistence ONLY.
# The frontend never reads or writes business tables via Supabase.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# ---------------------------------------------------------------------------
# FORBIDDEN in the frontend — never add these here. They are server-only
# secrets and Vite would leak them into the public bundle:
#   SUPABASE_SERVICE_ROLE_KEY
#   DATABASE_URL
#   SUPABASE_JWKS_URL
#   any Supabase Postgres / pooler credentials
# ---------------------------------------------------------------------------
