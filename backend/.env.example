# ---------------------------------------------------------------------------
# NubeRush backend — environment contract
#
# Copy this file to backend/.env and fill in real values. backend/.env is
# gitignored and must never hold committed secrets.
#
# F2.22.1 scope note: F2.22.1 changes ONLY the Postgres hosting/connection
# config. Auth, RLS, storage, realtime, and business logic are OUT OF SCOPE
# for this phase.
# ---------------------------------------------------------------------------

APP_NAME=NubeRush API
APP_ENV=development
APP_DEBUG=true

# ---------------------------------------------------------------------------
# DATABASE_URL — primary runtime database URL
#
# Read by app/core/config.py (DatabaseSettings) and by Alembic
# (alembic/env.py): the FastAPI app and migrations share this one value.
#
# Local development (active default below) — local Postgres remains fully
# supported and is the recommended local-dev setup:
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nuberush
#
# F2.22.1 Supabase cutover — point DATABASE_URL at the Supabase Supavisor
# SESSION pooler. Keep the `postgresql+psycopg://` driver prefix and require
# TLS with `?sslmode=require`. Example shape (placeholders, NOT real
# credentials):
#
#   DATABASE_URL=postgresql+psycopg://<user>:<password>@<supabase-session-pooler-host>:<port>/<database>?sslmode=require
#
# >>> Use the Supavisor SESSION pooler. Do NOT use the transaction pooler. <<<
# The transaction pooler can break SQLAlchemy session semantics, psycopg
# server-side prepared statements, SELECT ... FOR UPDATE row locks, and the
# inventory/orders concurrency tests. The session pooler assigns a dedicated
# backend per client connection and preserves all of the above.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# DATABASE_URL_TEST — isolated test database URL
#
# Consumed by the test harness (tests/conftest.py) via the environment; set
# it as a shell/CI variable. When unset it falls back to the local default
# shown below.
#
# The test suite runs `alembic upgrade head` and, with RESET_TEST_DB=1,
# `alembic downgrade base` — which DROPS schema objects. NEVER point
# DATABASE_URL_TEST at a production database. It must be an isolated test
# database or a separate Supabase project.
#
# Local default (used when DATABASE_URL_TEST is unset):
#   postgresql+psycopg://nuberush:nuberush@localhost:5432/nuberush_test
#
# F2.22.1 Supabase cutover — same SESSION pooler + `?sslmode=require` rules
# as DATABASE_URL. Example shape (placeholders, NOT real credentials):
#
#   DATABASE_URL_TEST=postgresql+psycopg://<test-user>:<test-password>@<supabase-session-pooler-host>:<port>/<test-database>?sslmode=require
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Legacy self-hosted JWT (POST /auth/login).
#
# F2.22.2.D scope note: as of F2.22.2.D, GET /auth/me and every protected
# endpoint verify SUPABASE access tokens (see the Supabase Auth block
# below). POST /auth/login still issues a self-hosted token using the
# secret below, but that token is no longer accepted by protected routes.
# These vars are kept until POST /auth/login is removed in a later subphase.
# ---------------------------------------------------------------------------

# DEVELOPMENT ONLY. The application refuses to start with this value when
# APP_ENV is anything other than "development". Generate a strong secret
# (>= 32 chars, e.g. `openssl rand -hex 32`) for staging/production.
JWT_SECRET_KEY=dev-only-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=nuberush-api
JWT_AUDIENCE=nuberush-client
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Supabase Auth — access-token verification (F2.22.2.D)
#
# FastAPI verifies Supabase-issued access tokens against the project's
# JWKS endpoint. The JWT establishes IDENTITY only — its `sub` is matched
# against public.users.auth_user_id. Role, store_id and is_active always
# come from public.users, never from token claims.
#
# SUPABASE_URL is the project base URL. When set, SUPABASE_JWKS_URL and
# SUPABASE_JWT_ISSUER are derived from it automatically; set them
# explicitly only to override. Placeholders below are NOT real values.
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Supabase service-role key — used by the Supabase Admin API for
# server-side user creation (POST /auth/users creates the auth.users
# record; F2.22.2.E). Required for real user creation. This is a
# SERVER-ONLY SECRET: keep it on the backend, never expose it to the
# frontend, never log it. Placeholder below, NOT a real key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
